{
  "manifest_version": 3,
  "name": "Rushuffle",
  "version": "1.0",
  "description": "Sort Gmail emails based on urgency using ML",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://*/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"]
    }
  ]
}
